[node name="clabel" type="Label" parent="inform/scroll/container"]
layout_mode = 2
mouse_filter = 1
text = "--------------------------------------------------
(?) Car Controls:
--------------------------------------------------"
horizontal_alignment = 1
clip_text = true

[node name="c" type="Label" parent="inform/scroll/container"]
layout_mode = 2
text = "Keyboard Steering:
W/Up = Accelerator
S/Down = Brake
A/Left = Steer Left
D/Right = Steer Right
K/Shift = Clutch
E/P = Shift Up
Q/L = Shift Down
Space/Ctrl = Handbrake

Mouse Steering:
Cursor (Horizontal Axis) = Steer
W/LMB = Accelerator
S/RMB = Brake
Shift = Clutch
E = Shift Up
Q = Shift Down
Space = Handbrake

Gamepad:
NOT CONFIGURED

Joystick:
NOT CONFIGURED

Steering Wheel:
UNSUPPORTED BY GODOT"
clip_text = true

[node name="clabel2" type="Label" parent="inform/scroll/container"]
layout_mode = 2
mouse_filter = 1
text = "--------------------------------------------------
(?) Misc Controls:
--------------------------------------------------"
horizontal_alignment = 1
clip_text = true

[node name="c2" type="Label" parent="inform/scroll/container"]
layout_mode = 2
text = "F11 = Toggle Fullscreen
Esc = Close All Panels
, = Pan Camera Left
. = Pan Camera Right
I = Zoom In
O = Zoom Out
/ = Reset Camera
F = Toggle Forces Visualisation"
clip_text = true

[node name="credlabel" type="Label" parent="inform/scroll/container"]
layout_mode = 2
text = "--------------------------------------------------
Credits/Sources:
--------------------------------------------------"
horizontal_alignment = 1
clip_text = true

